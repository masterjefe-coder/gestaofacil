generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum OpportunityStage {
  LEAD
  QUALIFIED
  QUOTE_SENT
  WON
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum ChargeStatus {
  PENDING
  DUE_TODAY
  PAID
  OVERDUE
  CANCELED
}

enum NfseStatus {
  DRAFT
  READY
  ISSUED
  ERROR
  CANCELED
}

enum SubscriptionPlan {
  ESSENTIAL
  PROFESSIONAL
  OPERATION
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum SubscriptionBillingCycle {
  MONTHLY
  YEARLY
}

enum BackgroundJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

model User {
  id          String               @id @default(cuid())
  name        String?
  email       String               @unique
  passwordHash String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  memberships WorkspaceMembership[]
  auditEvents AuditEvent[]         @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  alertPreferences WorkspaceUserPreference[]
}

model AuthThrottle {
  id             String   @id @default(cuid())
  identifier     String   @unique
  attemptCount   Int      @default(0)
  firstAttemptAt DateTime @default(now())
  lastAttemptAt  DateTime @default(now())
  lockedUntil    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PasswordResetToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  email       String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, expiresAt])
}

model Workspace {
  id            String                @id @default(cuid())
  name          String
  slug          String                @unique
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  memberships   WorkspaceMembership[]
  company       Company?
  customers     Customer[]
  services      ServiceCatalogItem[]
  opportunities Opportunity[]
  quotes        Quote[]
  orders        Order[]
  charges       Charge[]
  nfseDocuments NfseDocument[]
  auditEvents   AuditEvent[]
  backgroundJobs BackgroundJob[]
  subscription  WorkspaceSubscription?
  invites       WorkspaceInvite[]
  userPreferences WorkspaceUserPreference[]
}

model WorkspaceUserPreference {
  id                     String    @id @default(cuid())
  showOperationalAlerts  Boolean   @default(true)
  showNotificationCenter Boolean   @default(true)
  emailOnInviteAccepted  Boolean   @default(true)
  emailOnSecurityAlerts  Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  userId                 String
  workspaceId            String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace              Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, userId])
}

model WorkspaceSubscription {
  id                    String                   @id @default(cuid())
  plan                  SubscriptionPlan         @default(PROFESSIONAL)
  status                SubscriptionStatus       @default(TRIALING)
  billingCycle          SubscriptionBillingCycle @default(MONTHLY)
  trialStartedAt        DateTime?
  trialEndsAt           DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  canceledAt            DateTime?
  asaasCustomerId       String?
  asaasSubscriptionId   String?
  asaasPaymentLink      String?
  externalReference     String?
  notes                 String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  workspaceId           String                   @unique
  workspace             Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now())
  userId      String
  workspaceId String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id             String        @id @default(cuid())
  email          String
  name           String?
  role           WorkspaceRole @default(MEMBER)
  tokenHash      String        @unique
  tokenCiphertext String
  invitedByEmail String?
  expiresAt      DateTime
  sentAt         DateTime?
  lastSentAt     DateTime?
  sendCount      Int           @default(0)
  lastDeliveryError String?
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspaceId    String
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, email])
  @@index([workspaceId, expiresAt])
}

model Company {
  id                    String    @id @default(cuid())
  legalName             String
  tradeName             String?
  document              String    @unique
  city                  String?
  state                 String?
  municipalCode         String?
  serviceDescription    String?
  defaultFiscalServiceCode String?
  defaultPixKey         String?
  defaultPaymentMessage String?
  asaasApiKey           String?
  asaasAccountId        String?
  asaasWalletId         String?
  asaasUseOwnAccount    Boolean   @default(false)
  asaasSplitEnabled     Boolean   @default(false)
  evolutionInstanceName String?   @unique
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  workspaceId           String    @unique
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  email         String?
  phone         String?
  document      String?
  city          String?
  state         String?
  notes         String?
  deletedAt     DateTime?
  version       Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  quotes        Quote[]
  orders        Order[]
  charges       Charge[]
  nfseDocuments NfseDocument[]

  @@index([workspaceId, name])
  @@index([workspaceId, deletedAt])
}

model ServiceCatalogItem {
  id          String      @id @default(cuid())
  name        String
  description String?
  unitPrice   Decimal     @db.Decimal(10, 2)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  quoteItems  QuoteItem[]
  orderItems  OrderItem[]

  @@index([workspaceId, active])
}

model Opportunity {
  id             String           @id @default(cuid())
  title          String
  description    String?
  stage          OpportunityStage @default(LEAD)
  source         String?
  estimatedValue Decimal?         @db.Decimal(10, 2)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  customerId     String
  workspaceId    String
  customer       Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  quote          Quote?

  @@index([workspaceId, stage])
}

model Quote {
  id            String       @id @default(cuid())
  title         String
  summary       String?
  status        QuoteStatus  @default(DRAFT)
  subtotal      Decimal      @db.Decimal(10, 2)
  discount      Decimal      @default(0) @db.Decimal(10, 2)
  total         Decimal      @db.Decimal(10, 2)
  approvalToken String?      @unique
  approvedAt    DateTime?
  expiresAt     DateTime?
  deletedAt     DateTime?
  version       Int          @default(1)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  customerId    String
  workspaceId   String
  opportunityId String?      @unique
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  items         QuoteItem[]
  order         Order?

  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
}

model QuoteItem {
  id            String              @id @default(cuid())
  description   String
  quantity      Int                 @default(1)
  unitPrice     Decimal             @db.Decimal(10, 2)
  total         Decimal             @db.Decimal(10, 2)
  quoteId       String
  serviceItemId String?
  quote         Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceItem   ServiceCatalogItem? @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)
}

model Order {
  id            String      @id @default(cuid())
  status        OrderStatus @default(PENDING)
  scheduledFor  DateTime?
  completedAt   DateTime?
  internalNotes String?
  deletedAt     DateTime?
  version       Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  quoteId       String      @unique
  customerId    String
  workspaceId   String
  quote         Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  charges       Charge[]
  nfseDocument  NfseDocument?

  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
}

model OrderItem {
  id            String              @id @default(cuid())
  description   String
  quantity      Int                 @default(1)
  unitPrice     Decimal             @db.Decimal(10, 2)
  total         Decimal             @db.Decimal(10, 2)
  orderId       String
  serviceItemId String?
  order         Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceItem   ServiceCatalogItem? @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)
}

model Charge {
  id            String       @id @default(cuid())
  amount        Decimal      @db.Decimal(10, 2)
  status        ChargeStatus @default(PENDING)
  paymentMethod String
  paymentLink   String?
  pixCode       String?
  dueDate       DateTime?
  paidAt        DateTime?
  deletedAt     DateTime?
  version       Int         @default(1)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspaceId   String
  customerId    String
  orderId       String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
}

model NfseDocument {
  id               String     @id @default(cuid())
  status           NfseStatus @default(DRAFT)
  externalId       String?
  verificationCode String?
  serviceAmount    Decimal    @db.Decimal(10, 2)
  issuedAt         DateTime?
  errorMessage     String?
  deletedAt        DateTime?
  version          Int        @default(1)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  workspaceId      String
  customerId       String
  orderId          String     @unique
  workspace        Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer         Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order            Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
}

model BackgroundJob {
  id           String              @id @default(cuid())
  type         String
  payload      Json
  status       BackgroundJobStatus @default(PENDING)
  dedupeKey    String?
  attempts     Int                 @default(0)
  maxAttempts  Int                 @default(3)
  scheduledFor DateTime            @default(now())
  availableAt  DateTime            @default(now())
  lockedAt     DateTime?
  lockedBy     String?
  lastError    String?
  completedAt  DateTime?
  failedAt     DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  workspaceId  String?
  workspace    Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([type, dedupeKey])
  @@index([status, availableAt])
  @@index([workspaceId, status])
}

model RateLimitBucket {
  id         String   @id @default(cuid())
  scope      String
  identifier String
  windowKey  String
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([scope, identifier, windowKey])
  @@index([resetAt])
}

model AuditEvent {
  id          String    @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  payload     Json?
  createdAt   DateTime  @default(now())
  workspaceId String
  actorId     String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor       User?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, entityType, entityId])
}
