# Gestao Facil production env example for Oracle VM

NODE_ENV=production
PORT=3002
HOSTNAME=127.0.0.1
APP_BASE_URL=https://www.gestaofacilsistemas.com.br
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/gestaofacil
AUTH_SECRET=change-me
WORKSPACE_SECRET_KEY=change-me
GESTAO_FACIL_DATA_MODE=database

# Optional health endpoint token
HEALTHCHECK_TOKEN=

# Optional integrations
EVOLUTION_API_BASE_URL=http://127.0.0.1:8081
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=production
ASAAS_WEBHOOK_AUTH_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=
