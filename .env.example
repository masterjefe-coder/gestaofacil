# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestao_facil?schema=public"

# Authentication & Security (CRITICAL - Must be 32+ characters in production)
# Generate with: openssl rand -hex 32
AUTH_SECRET="troque-por-um-segredo-forte-minimo-32-caracteres"
WORKSPACE_SECRET_KEY="troque-por-um-segredo-forte-e-exclusivo-minimo-32-caracteres"

# Demo Account (Optional - for testing only)
AUTH_DEMO_EMAIL="demo@gestaofacil.local"
AUTH_DEMO_PASSWORD="gestao123"

# Application Configuration
NODE_ENV="development"
GESTAO_FACIL_DATA_MODE="database"
GESTAO_FACIL_ENABLE_PUBLIC_DEMO="false"
APP_BASE_URL=""

# Health Check (Optional - for monitoring)
HEALTHCHECK_TOKEN=""

# Evolution API Configuration (WhatsApp Integration)
EVOLUTION_API_BASE_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_API_INSTANCE=""
EVOLUTION_API_TIMEOUT_MS="15000"
EVOLUTION_WEBHOOK_URL=""
# CRITICAL: Must be 32+ characters in production
# Generate with: openssl rand -hex 32
EVOLUTION_WEBHOOK_SECRET=""

# Asaas Payment Gateway Configuration
ASAAS_API_KEY=""
ASAAS_ENVIRONMENT="sandbox"
# CRITICAL: Must be 32+ characters in production
# Generate with: openssl rand -hex 32
ASAAS_WEBHOOK_AUTH_TOKEN=""
ASAAS_ALLOW_ROOT_ACCOUNT_FALLBACK="true"
ASAAS_PLATFORM_WALLET_ID=""
ASAAS_PLATFORM_SPLIT_PERCENT=""
ASAAS_PLATFORM_SPLIT_FIXED_VALUE=""

# Email Configuration (Transactional Emails)
RESEND_API_KEY=""
EMAIL_FROM="Gestao Facil <convites@gestaofacilsistemas.com.br>"

# NFSe National Configuration (Fiscal Notes)
NFSE_NATIONAL_ENABLED="false"
NFSE_NATIONAL_ENVIRONMENT="restricted"
NFSE_NATIONAL_MUNICIPAL_CODE=""
NFSE_NATIONAL_SERVICE_CODE=""
NFSE_NATIONAL_SERIES="90000"
NFSE_NATIONAL_CERT_PFX_BASE64=""
NFSE_NATIONAL_CERT_PFX_PATH=""
NFSE_NATIONAL_CERT_PASSPHRASE=""
NFSE_NATIONAL_TIMEOUT_MS="15000"

# Security Notes:
# 1. Never commit actual secrets to version control
# 2. Use strong, randomly generated secrets (32+ characters)
# 3. Rotate secrets regularly in production
# 4. Use different secrets for each environment
# 5. Store production secrets in secure secret management systems
